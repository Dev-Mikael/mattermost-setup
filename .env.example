# =============================================================
# mattermost-setup — Environment Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# .env is gitignored — NEVER commit it
# =============================================================

# ----- Git & GitHub -----
GITHUB_USER=your-github-username
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=mattermost-setup
GITHUB_BRANCH=main

# ----- Cluster -----
CLUSTER_NAME=production
CLUSTER_TYPE=kind

# ----- SSH (kubeadm only) -----
SSH_KEY_PATH=./server-key.pem
SSH_USER=ubuntu

# ----- Networking -----
SERVER_IP=127.0.0.1
DOMAIN=modumichael.me
LETSENCRYPT_EMAIL=admin@modumichael.me

# ----- Mattermost DB + Storage -----
DB_PASSWORD=change-me-strong-password-here
MINIO_ACCESS_KEY=mattermost-minio
MINIO_SECRET_KEY=change-me-minio-secret-here

# ----- MetalLB -----
METALLB_IP_RANGE=
SERVER_PRIVATE_IP=

# =============================================================
# ----- Mattermost Admin Account -----
# Script 06 uses these to call the Mattermost REST API (via a
# temporary port-forward) to create the openclaw-bot account
# and generate its access token. These are used transiently —
# never stored in a secret or committed to git.
# The admin account is created via the Mattermost CLI inside
# the pod using --system_admin.
# MM_ADMIN_EMAIL defaults to LETSENCRYPT_EMAIL if not set.
# =============================================================
MM_ADMIN_USERNAME=admin
MM_ADMIN_PASSWORD=change-me-strong-admin-password
# MM_ADMIN_EMAIL=admin@modumichael.me   # optional, defaults to LETSENCRYPT_EMAIL

# =============================================================
# ----- KubeClaw / OpenClaw -----
# =============================================================

# Strong random token protecting the OpenClaw Web UI and Gateway API.
# Generate: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=change-me-strong-gateway-token-here

# Anthropic API key (Claude models via LiteLLM)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini API key
GEMINI_API_KEY=your-gemini-key-here

# LiteLLM internal master key — MUST start with 'sk-'. Never exposed externally.
# Generate: openssl rand -hex 24 | sed 's/^/sk-/'
LITELLM_MASTER_KEY=sk-change-me-litellm-key

# =============================================================
# ----- Bot behaviour -----
# =============================================================

# DM policy for the openclaw-bot:
#   pairing — first DM from an unknown user returns a pairing code.
#             Admin approves via: bash scripts/07-manage-bot.sh (option 3)
#             Use this for controlled access (recommended for team deployments).
#   open    — any Mattermost user can DM the bot freely with no approval step.
#             Use this if you want zero friction for all users.
MM_BOT_DM_POLICY=pairing

# Comma-separated list of Mattermost channel names to add the bot to automatically.
# The bot will respond in these channels when @mentioned (chatmode: oncall).
# Channel names are the URL-slug format (lowercase, hyphens), e.g.:
#   town-square,general,engineering,ops
MM_BOT_CHANNELS=town-square
