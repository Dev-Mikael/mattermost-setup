# =============================================================
# mattermost-setup — Environment Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# .env is gitignored — NEVER commit it
# =============================================================

# ----- Git & GitHub -----
GITHUB_USER=your-github-username
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=mattermost-setup
GITHUB_BRANCH=main

# ----- Cluster -----
CLUSTER_NAME=production
# CLUSTER_TYPE: "kind" for local dev/test | "kubeadm" for real on-prem server
CLUSTER_TYPE=kind

# ----- SSH (required for CLUSTER_TYPE=kubeadm) -----
# Path to your private key — relative to the repo root or absolute path.
# AWS: download the .pem from EC2 console and place it in this folder.
# Example: SSH_KEY_PATH=./my-server.pem   or   SSH_KEY_PATH=/home/you/.ssh/id_rsa
SSH_KEY_PATH=./server-key.pem
# SSH username for your server OS image:
#   AWS Ubuntu  → ubuntu
#   AWS Amazon Linux → ec2-user
#   AWS Debian  → admin
#   DigitalOcean / Hetzner root → root
SSH_USER=ubuntu

# ----- Networking -----
# For kind:    use 127.0.0.1
# For kubeadm: use your server's real public IP e.g. 203.0.113.10
SERVER_IP=127.0.0.1

# Your domain name
DOMAIN=modumichael.me

# Email for Let's Encrypt TLS certificates (on-prem only)
LETSENCRYPT_EMAIL=admin@modumichael.me

# ----- Secrets -----
# PostgreSQL database password (min 16 chars)
DB_PASSWORD=change-me-strong-password-here

# MinIO object storage credentials
MINIO_ACCESS_KEY=mattermost-minio
MINIO_SECRET_KEY=change-me-minio-secret-here

# MetalLB IP range — auto-set by scripts to the server's PRIVATE IP.
# On AWS/cloud: set to the private IP (e.g. 10.0.1.5/32), NOT the public IP.
# The public IP is a cloud NAT — MetalLB cannot claim it via ARP.
# Leave blank here; 02b-setup-kubeadm.sh writes the correct value automatically.
METALLB_IP_RANGE=

# Private IP of the server (auto-filled by 02b-setup-kubeadm.sh for kubeadm).
# On kind: defaults to SERVER_IP (127.0.0.1). Do not set manually.
SERVER_PRIVATE_IP=
